NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- KONEKSI DATABASE (SUPABASE) ---
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- SECURITY ---
JWT_SECRET=your_jwt_secret_64_hex_chars_here
RESET_SECRET=your_password_reset_base64_secret_here
CSRF_SECRET=your_csrf_secret_random_string_here
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost

# --- AI INTEGRATION ---
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o

# --- EMAIL (SMTP) ---
EMAIL_ENABLED=false
EMAIL_FROM_ADDRESS="Redaksi BeritaKarya <redaksi@beritakarya.co>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_gmail_user_here
SMTP_PASS=your_gmail_app_password_here

# --- S3 STORAGE (SUPABASE STORAGE S3 API) ---
S3_ENDPOINT="https://[PROJECT_REF].supabase.co/storage/v1/s3"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY="[ACCESS_KEY]"
S3_SECRET_KEY="[SECRET_KEY]"
S3_FORCE_PATH_STYLE=true
S3_BUCKET="kyc"
S3_MEDIA_BUCKET="media"

# --- CDN CONFIGURATION (Required for media upload) ---
# Base URL untuk bucket publik Supabase Storage
# Format: https://<PROJECT_REF>.supabase.co/storage/v1/object/public
SUPABASE_STORAGE_PUBLIC_URL="https://<PROJECT_REF>.supabase.co/storage/v1/object/public"

# --- ERROR MONITORING ---
SENTRY_DSN=