{
  "name": "@beritakarya/api",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --project tsconfig.scripts.json src/db/seed.ts",
    "db:seed:categories": "ts-node --project tsconfig.scripts.json scripts/seed-categories-from-config.ts",
    "cleanup:trial": "ts-node --project tsconfig.scripts.json scripts/cleanup-trial-content.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@beritakarya/config": "workspace:*",
    "@beritakarya/types": "workspace:*",
    "@beritakarya/utils": "workspace:*",
    "@prisma/client": "^5.12.0",
    "@sentry/node": "^10.53.1",
    "bcryptjs": "^2.4.3",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.0.9",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.2.0",
    "file-type": "^22.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsdom": "^24.0.0",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.39.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "openai": "^4.28.0",
    "opossum": "^9.0.0",
    "rate-limit-redis": "^5.0.0",
    "sharp": "^0.33.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-timeout": "^1.9.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/opossum": "^8.1.9",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "prisma": "^5.12.0",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}