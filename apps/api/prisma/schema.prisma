generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum KycStatus {
  UNSUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  reader
  reporter
  kontributor
  wapimred
  superadmin
  advertiser
}

enum ArticleStatus {
  draft
  submitted
  review
  revision
  approved
  scheduled
  published
  archived
  rejected
}

enum ContentType {
  article
  photo_journalism
  video_exclusive
}

model Site {
  id                   String    @id
  name                 String
  domain               String    @unique
  description          String?
  logoUrl              String?
  faviconUrl           String?
  ogImageUrl           String?
  footerText           String?
  address              String?
  contactEmail         String?
  phone                String?
  aboutUs              String?   @db.Text
  codeOfEthics         String?   @db.Text
  editorial            String?   @db.Text
  advertising          String?   @db.Text
  privacyPolicy        String?   @db.Text
  termsOfService       String?   @db.Text
  mediaSiber          String?   @db.Text
  socialLinks          Json?     @default("{}")
  appearance           Json?     @default("{\"primaryColor\":\"#e11d48\"}")
  trendingTopics       Json?     @default("[]")
  googleIndexingConfig Json?     @default("{}")
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users                 User[]
  articles              Article[]
  categories            Category[]
  advertisements        Advertisement[]
  newsletterSubscribers NewsletterSubscriber[]
  comments              Comment[]
  pageViews             PageView[]
  kycViewLogs           KYCViewLog[]
  aiUsage               AIUsage[]
  media                 Media[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  adBookings            AdBooking[]
  siteCategories        SiteCategory[]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(reader)
  siteId       String?
  deletedAt    DateTime?

  // KYC Fields
  bio               String?   @db.Text
  idCardPath        String?
  familyCardPath    String?
  isVerified        Boolean   @default(false)
  kycStatus         KycStatus @default(UNSUBMITTED)
  kycSubmittedAt    DateTime?
  kycNotes          String?
  kycReviewedBy     String? // userId admin yang approval
  kycReviewedAt     DateTime?
  kycConsentGivenAt DateTime? // Waktu user setuju kebijakan data
  kycDataExpiresAt  DateTime? // Auto-delete after X years (GDPR compliance)
  kycAttempts       Int       @default(0) // Number of failed KYC attempts (max 3)
  kycLockedUntil    DateTime? // Account lock until this timestamp

  // AI Quota Fields
  aiEnabled          Boolean   @default(true)
  aiDailyLimit       Int       @default(50) // Daily request limit
  aiMonthlyBudget    Decimal   @default(10.00) // Monthly budget in USD
  aiFeaturesAllowed  Json      @default("[\"rewrite\",\"expand\",\"grammar\",\"readability\",\"caption\"]") // Allowed AI features
  aiQuotaResetDate   DateTime? // Manual reset date tracking
  aiModelRestriction String? // Force specific model (e.g., 'gpt-3.5-turbo')
  aiConsentGivenAt   DateTime? // Waktu user setuju dengan ketentuan penggunaan AI

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site          Site?          @relation(fields: [siteId], references: [id])
  articles      Article[]
  refreshTokens RefreshToken[]
  comments      Comment[]
  kycViewLogs   KYCViewLog[]
  invitations   Invitation[] // Invitations sent by this user
  aiUsage       AIUsage[]
  media         Media[]
  auditLogs     AuditLog[]
  notifications Notification[]
  adBookings    AdBooking[]

  @@index([siteId])
  @@index([email])
  @@index([isVerified])
  @@index([kycStatus])
  @@index([kycSubmittedAt])
  @@index([kycAttempts])
  @@index([kycLockedUntil])
  @@index([deletedAt])
  @@index([aiEnabled])
  @@index([siteId, isVerified, kycSubmittedAt])
  @@index([siteId, kycStatus, kycSubmittedAt])
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String
  siteId      String? // NULL = global category (available to all sites)
  isGlobal    Boolean   @default(false) @map("is_global")
  description String?
  parentId    String?   @map("parent_id")
  order       Int       @default(0)
  color       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site          Site?      @relation(fields: [siteId], references: [id])
  articles      Article[]
  parent          Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subCategories   Category[]     @relation("CategoryHierarchy")
  siteAssignments SiteCategory[]

  // Unique constraint: allows (slug, NULL) for global categories
  // and (slug, siteId) for site-specific categories
  @@unique([slug, siteId])
  @@index([siteId])
  @@index([isGlobal])
  @@index([deletedAt])
}

model SiteCategory {
  siteId     String   @map("site_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([siteId, categoryId])
  @@index([categoryId])
  @@map("site_categories")
}

model Advertisement {
  id          String   @id @default(uuid())
  siteId      String
  slot        String // 'leaderboard' | 'rectangle' | 'rectangle_secondary' | 'in_feed'
  code        String? // HTML/JS snippet like Google AdSense
  imageUrl    String? // If they just want to upload an image banner
  linkUrl     String? // Where the banner clicks to
  isActive    Boolean  @default(true)
  order       Int      @default(0) // Rotation order for carousel (leaderboard)
  impressions Int      @default(0) // Tracker for views
  clicks      Int      @default(0) // Tracker for clicks
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, slot])
}

model Article {
  id         String  @id @default(uuid())
  title      String
  slug       String
  excerpt    String?
  siteId     String
  categoryId String?
  authorId   String
  blocks      Json        @default("[]")
  tags        Json        @default("[]")
  contentType ContentType @default(article) @map("content_type")

  // Editorial Workflow
  // Editorial Workflow
  status      ArticleStatus @default(draft)
  reviewedBy  String? // userId pimred yang mereview
  reviewedAt  DateTime?
  reviewNotes String? // Catatan revisi dari editor
  scheduledAt DateTime? // Waktu terbit yang dijadwalkan

  // SEO
  metaTitle         String?
  metaDescription   String?
  featuredImage     String? // URL gambar utama
  featuredImageBlur String? // Base64 blur hash (10x10 webp)
  featuredImageColor String? // Hex dominant color

  // Article Metadata
  wordCount      Int? // Jumlah kata
  readingTimeMin Int? // Estimasi menit baca
  viewCount      Int              @default(0)
  shareCount     Int              @default(0)
  versions       ArticleVersion[]

  // Editorial Flags
  isBreaking  Boolean @default(false)
  isExclusive Boolean @default(false)
  isFeatured  Boolean @default(false)

  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site      Site       @relation(fields: [siteId], references: [id])
  author    User       @relation(fields: [authorId], references: [id])
  category  Category?  @relation(fields: [categoryId], references: [id])
  comments  Comment[]
  pageViews PageView[]

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([authorId])
  @@index([categoryId])
  @@index([scheduledAt])
  @@index([publishedAt, viewCount])
  @@index([siteId, status, publishedAt])
  @@index([deletedAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model AIUsage {
  id            String   @id @default(uuid())
  userId        String
  siteId        String
  action        String
  inputLength   Int
  outputLength  Int
  latencyMs     Int
  success       Boolean
  estimatedCost Decimal? // Cost in USD
  modelUsed     String? // AI model used (gpt-4o, gpt-3.5-turbo, etc.)
  tokensInput   Int? // Input tokens (if available from API)
  tokensOutput  Int? // Output tokens (if available from API)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id])

  @@index([userId, action])
  @@index([siteId])
  @@index([userId, createdAt])
  @@index([siteId, createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String
  siteId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@unique([siteId, email])
  @@index([siteId])
}

model Media {
  id             String   @id @default(uuid())
  url            String
  thumbUrl       String
  blurHash       String? // Base64 blur hash (10x10 webp)
  dominantColor  String? // Hex dominant color (#2B579C)
  width          Int
  height         Int
  originalFormat String
  size           Int
  altText        String? // Teks alt untuk aksesibilitas & SEO
  caption        String? // Keterangan foto
  credit         String? // Kredit/sumber foto
  userId         String
  siteId         String?
  createdAt      DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  site Site? @relation(fields: [siteId], references: [id])

  @@index([siteId])
}

model Comment {
  id          String   @id @default(uuid())
  content     String   @db.Text
  articleId   String
  siteId      String
  authorId    String? // Optional: if logged in
  authorName  String? // If guest
  authorEmail String?
  status      String   @default("pending") // pending | approved | spam
  parentId    String? // For nested replies
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  article Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site    Site      @relation(fields: [siteId], references: [id])
  user    User?     @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([articleId])
  @@index([siteId, status])
}

model PageView {
  id        String   @id @default(uuid())
  siteId    String
  articleId String?
  path      String // e.g. /artikel/slug atau /
  referrer  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  site    Site     @relation(fields: [siteId], references: [id])
  article Article? @relation(fields: [articleId], references: [id])

  @@index([siteId, createdAt])
  @@index([articleId, createdAt])
}

model ArticleVersion {
  id        String   @id @default(uuid())
  articleId String
  title     String
  blocks    Json     @default("[]")
  version   Int
  authorId  String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// Audit log untuk akuntabilitas semua aksi redaksi
model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  siteId     String
  action     String // e.g. article.publish | article.review | user.create | settings.update
  entityType String? // 'article' | 'user' | 'site' | 'category'
  entityId   String? // ID entitas yang diubah
  oldValue   Json? // State sebelumnya
  newValue   Json? // State sesudahnya
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  site Site @relation(fields: [siteId], references: [id])

  @@index([userId])
  @@index([siteId, action])
  @@index([entityId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  siteId    String
  type      String // e.g. article_submitted | article_reviewed | mention
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id])

  @@index([userId])
  @@index([siteId])
}

// Audit trail untuk akses file KYC
model KYCViewLog {
  id        String   @id @default(uuid())
  userId    String // user yang KYC-nya dilihat
  viewerId  String // admin yang melihat
  siteId    String
  fileType  String // 'ktp' | 'kk' | 'bio'
  viewedAt  DateTime @default(now())
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id])
  site Site @relation(fields: [siteId], references: [id])

  @@index([userId, viewedAt])
  @@index([viewerId])
  @@index([siteId])
}

// Quota definitions per role
model RoleQuota {
  role             Role    @id
  dailyRequests    Int // Daily request limit
  dailyTokens      Int // Daily token limit
  monthlyBudget    Decimal // Monthly budget in USD
  allowedFeatures  Json // Array of allowed feature endpoints
  modelRestriction String? // Force specific model (e.g., 'gpt-3.5-turbo')

  @@map("RoleQuota")
}

// Invitation system for admin to invite users with predefined roles
model Invitation {
  id         String    @id @default(uuid())
  email      String // Email yang diundang
  token      String    @unique // Token untuk accept invitation
  role       Role      @default(reader) // Role yang akan diberikan
  siteId     String? // Site yang diundang (null = all sites / superadmin context)
  invitedBy  String // Admin yang mengundang
  expiresAt  DateTime // Token expiry (usually 7 days)
  acceptedAt DateTime? // Waktu invitation diterima
  createdAt  DateTime  @default(now())

  invitedByUser User @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([email, siteId])
  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@index([siteId])
  @@index([invitedBy])
}

// Katalog Paket Iklan yang dibuat oleh Superadmin
model AdPackage {
  id            String      @id @default(uuid())
  name          String // Contoh: "Banner Leaderboard Mingguan"
  slot          String // 'leaderboard' | 'rectangle' | 'rectangle_secondary' | 'in_feed'
  durationDays  Int // Durasi tayang dalam hari (misal: 3, 7, 30)
  price         Decimal     @db.Decimal(12, 2) // Biaya dalam Rupiah
  allowedFormat String      @default("ALL") // 'IMAGE' | 'VIDEO' | 'ALL'
  description   String?     @db.Text
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bookings      AdBooking[]
}

// Transaksi Pemesanan Iklan oleh Advertiser
model AdBooking {
  id             String        @id @default(uuid())
  userId         String
  siteId         String
  packageId      String
  imageUrl       String? // File banner gambar WebP
  linkUrl        String? // Tautan target ketika diklik
  startDate      DateTime
  endDate        DateTime
  paymentStatus  PaymentStatus @default(PENDING)
  paymentProof   String? // Bukti transfer bank/QRIS
  status         AdStatus      @default(PENDING_REVIEW)
  rejectionNotes String?       @db.Text
  impressions    Int           @default(0)
  clicks         Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  site    Site      @relation(fields: [siteId], references: [id])
  package AdPackage @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@index([siteId])
  @@index([packageId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  VERIFYING
  PAID
  REJECTED
}

enum AdStatus {
  PENDING_REVIEW
  ACTIVE
  COMPLETED
  REJECTED
}
