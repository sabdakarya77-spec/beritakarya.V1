NODE_ENV=production
PORT=3001
API_URL=https://api.beritakarya.co
FRONTEND_URL=https://beritakarya.co
NEXT_PUBLIC_API_URL=https://api.beritakarya.co

# --- DATABASE SETUP ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_production_postgres_password_here
POSTGRES_DB=beritakarya_prod

# --- KONEKSI DATABASE PRISMA ---
# Di Docker, host database adalah 'postgres' (nama service di docker-compose)
DATABASE_URL=postgresql://postgres:your_production_postgres_password_here@postgres:5432/beritakarya_prod
DIRECT_URL=postgresql://postgres:your_production_postgres_password_here@postgres:5432/beritakarya_prod

# --- SECURITY ---
JWT_SECRET=your_jwt_secret_64_hex_chars_here
RESET_SECRET=your_password_reset_base64_secret_here
CSRF_SECRET=your_csrf_secret_random_string_here
CORS_ORIGIN=https://beritakarya.co,https://www.beritakarya.co
COOKIE_DOMAIN=.beritakarya.co

# --- SERVICES ---
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o

# Redis & Meilisearch (Host menggunakan nama service Docker)
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_KEY_PREFIX=bk:prod:
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=your_meilisearch_master_key_here
# SENTRY_DSN=

# --- EMAIL ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_gmail_user_here
SMTP_PASS=your_gmail_app_password_here

# --- CDN ---
# CDN_URL=https://cdn.beritakarya.co
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
CLOUDINARY_URL=cloudinary://your_cloudinary_api_key:your_cloudinary_api_secret@your_cloudinary_cloud_name

# --- VERCEL DNS API (acme.sh Wildcard SSL Renewal) ---
VERCEL_TOKEN=your_vercel_api_token_here

# --- LOGGING & PROXY ---
# TRUST_PROXY=1
# LOG_HTTP_HOST=http://logstash:5044
