{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@beritakarya/types": ["packages/types/src"],
      "@beritakarya/config": ["packages/config/src"],
      "@beritakarya/utils": ["packages/utils/src"]
    }
  },
  "exclude": ["**/node_modules", "**/dist"]
}
